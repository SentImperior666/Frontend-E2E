# --- Figma ---
FIGMA_FILE_KEY=
FIGMA_API_TOKEN=          # read scope only
FIGMA_WRITE_TOKEN=        # file_content:write — required for /figma-publish

# --- Stitch ---
# Use either an API key OR the OAuth pair below. The harness defaults to API key.
STITCH_API_KEY=
# STITCH_ACCESS_TOKEN=
# GOOGLE_CLOUD_PROJECT=
STITCH_PROJECT_ID=        # populated automatically by stitch-init-project on first run
STITCH_PROJECT_PURPOSE=rpg-site

# --- Target site (Vite + Svelte + Tailwind) ---
TARGET_REPO_PATH=
TARGET_TOKENS_PATH=src/lib/tokens
TARGET_DEFAULT_COMPONENT_PATH=src/lib/components   # fallback only — placement script picks per-component
TARGET_PARITY_PATH=tests/parity
TARGET_ASSETS_PATH=static/assets/stitch
TARGET_GRAPH_TTL_MINUTES=60                         # auto-refresh threshold for the scan graph

# --- Visual review ---
ARGOS_TOKEN=

# --- Lighthouse / a11y ---
LHCI_GITHUB_APP_TOKEN=
