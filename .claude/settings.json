{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm install --frozen-lockfile)",
      "Bash(pnpm run *)",
      "Bash(pnpm dlx *)",
      "Bash(pnpm tokens:sync)",
      "Bash(pnpm stitch:*)",
      "Bash(pnpm scan:target)",
      "Bash(pnpm placement:*)",
      "Bash(pnpm sync:*)",
      "Bash(pnpm extract:*)",
      "Bash(pnpm test*)",
      "Bash(pnpm storybook*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm figma:*)",
      "Bash(pnpm parity:*)",
      "Bash(npx playwright *)",
      "Bash(node scripts/*)",
      "Bash(tsx scripts/*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list*)",
      "Bash(gh api *)",
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Edit(src/**)",
      "Edit(scripts/**)",
      "Edit(prompts/**)",
      "Edit(docs/**)",
      "Edit(.claude/**)",
      "Edit(.github/**)",
      "Edit(.storybook/**)",
      "Write(src/**)",
      "Write(scripts/**)",
      "Write(prompts/**)",
      "Write(docs/**)",
      "Write(.lostpixel/**)",
      "Write(.stitch/**)",
      "Write(.harness/**)",
      "Write(public/**)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git commit *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Edit($TARGET_REPO_PATH/**)",
      "Write($TARGET_REPO_PATH/**)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Edit(.env)",
      "Read(.env)"
    ]
  },
  "env": {
    "STITCH_PROJECT_PURPOSE": "rpg-site",
    "TARGET_GRAPH_TTL_MINUTES": "60"
  }
}
