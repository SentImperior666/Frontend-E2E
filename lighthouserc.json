{
  "ci": {
    "collect": {
      "staticDistDir": "./storybook-static",
      "url": [
        "http://localhost/iframe.html?id=character-sheet--default",
        "http://localhost/iframe.html?id=spell-card--default",
        "http://localhost/iframe.html?id=dice-tray--default",
        "http://localhost/iframe.html?id=combat-tracker--default",
        "http://localhost/iframe.html?id=inventory-grid--default",
        "http://localhost/iframe.html?id=npc-dialogue--default",
        "http://localhost/iframe.html?id=lobby-list--default",
        "http://localhost/iframe.html?id=journal-entry--default"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "throttling": {
          "rttMs": 150,
          "throughputKbps": 1638.4,
          "cpuSlowdownMultiplier": 4
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.7 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 3500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["error", { "maxNumericValue": 300 }],
        "resource-summary:script:size": ["error", { "maxNumericValue": 358400 }],
        "resource-summary:image:size": ["error", { "maxNumericValue": 819200 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
