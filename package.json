{
  "name": "frontend-e2e",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Stitch + Figma-driven workshop and Svelte porting harness for a tabletop RPG site.",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "storybook:test": "test-storybook",
    "test": "vitest run",
    "test:isolated": "vitest run && test-storybook --url http://127.0.0.1:6006",
    "test:combined": "playwright test --project=scenarios",
    "test:a11y": "playwright test --project=axe",
    "test:perf": "lhci autorun",
    "test:visual": "lost-pixel",
    "test:parity": "playwright test --project=parity",
    "tokens:sync": "tsx scripts/update-tokens.ts",
    "stitch:init": "tsx scripts/stitch-init-project.ts",
    "stitch:sync-ds": "tsx scripts/stitch-sync-design-system.ts",
    "stitch:generate": "tsx scripts/stitch-generate.ts",
    "stitch:edit": "tsx scripts/stitch-edit.ts",
    "stitch:variants": "tsx scripts/stitch-variants.ts",
    "stitch:render-baseline": "tsx scripts/stitch-render-baseline.ts",
    "scan:target": "tsx scripts/scan-target-components.ts",
    "placement:find": "tsx scripts/find-component-placement.ts",
    "sync:target-tokens": "tsx scripts/sync-target-tokens.ts",
    "sync:target-assets": "tsx scripts/sync-target-assets.ts",
    "extract:target-theme": "tsx scripts/extract-target-theme.ts",
    "figma:publish": "tsx scripts/figma-publish-frame.ts",
    "figma:publish:prepare": "tsx scripts/figma-publish-frame.ts prepare",
    "figma:publish:update-mapping": "tsx scripts/figma-publish-frame.ts update-mapping",
    "figma:export-baselines": "tsx scripts/figma-export-baselines.ts",
    "parity:capture": "tsx scripts/parity-capture.ts"
  },
  "dependencies": {
    "@google/stitch-sdk": "^0.1.1",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@argos-ci/cli": "^2.5.0",
    "@argos-ci/storybook": "^4.0.0",
    "@axe-core/playwright": "^4.10.0",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.48.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/nextjs": "^8.4.0",
    "@storybook/react": "^8.4.0",
    "@storybook/test-runner": "^0.20.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "fast-glob": "^3.3.2",
    "lost-pixel": "^3.22.0",
    "playwright": "^1.48.0",
    "storybook": "^8.4.0",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
